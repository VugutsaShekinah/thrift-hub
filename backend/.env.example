# Copy to .env and fill in real values. Never commit the real .env file.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Database (PostgreSQL) ---
DB_NAME=thrifthub
DB_USER=thrifthub
DB_PASSWORD=thrifthub
DB_HOST=localhost
DB_PORT=5432

# --- CORS / Frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Email (dev default prints to console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ThriftHub KE <no-reply@thrifthub.co.ke>

# --- Business constants (Kenya) ---
VAT_RATE=0.16
DEFAULT_SHIPPING_FEE_KES=250
FREE_SHIPPING_THRESHOLD_KES=5000
RETURN_WINDOW_HOURS=48

# --- Payments ---
# "mock" for local dev/test (instant simulated success), "mpesa" once Daraja
# credentials below are real and MPESA_CALLBACK_URL is a public HTTPS endpoint.
PAYMENT_PROVIDER=mock
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox

# --- Production-only (S3-compatible media storage) ---
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
